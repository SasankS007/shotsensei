# Required for browser auth client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional server-side aliases (useful in some deploy setups)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

BACKEND_URL=http://localhost:8000
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Optional — ElevenLabs TTS for UI / score voice (see lib/tamagotchiAudio.ts)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_PUBLISHABLE_KEY=your-roboflow-publishable-key
